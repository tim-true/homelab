{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {"list": []},
  "description": "QNAP NAS monitoring via SNMP",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["qnap", "nas", "snmp"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "QNAP NAS",
  "uid": "qnap-nas-monitor",
  "version": 2,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {"selected": false, "text": "192.168.1.34", "value": "192.168.1.34"},
        "hide": 0,
        "label": "Instance",
        "name": "instance",
        "options": [{"selected": true, "text": "192.168.1.34", "value": "192.168.1.34"}],
        "query": "192.168.1.34",
        "type": "custom"
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "CPU Usage (avg)",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "avg(hrProcessorLoad{instance=\"$instance\"})",
          "legendFormat": "CPU",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "CPU Temperature",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapCPUTemp_c{instance=\"$instance\"}",
          "legendFormat": "CPU",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 65},
              {"color": "red", "value": 80}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Memory Usage",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "physicalMemoryUsed{instance=\"$instance\"} / physicalMemorySize{instance=\"$instance\"} * 100",
          "legendFormat": "Memory",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Fan Speed",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapFanSpeed{instance=\"$instance\"}",
          "legendFormat": "{{fanID}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rotrpm",
          "color": {"mode": "fixed", "fixedColor": "blue"}
        },
        "overrides": []
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Disk Temperatures",
      "gridPos": {"x": 18, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapDiskTemp_c{instance=\"$instance\"}",
          "legendFormat": "{{diskID}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 45},
              {"color": "red", "value": 55}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "CPU Usage per Core",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "hrProcessorLoad{instance=\"$instance\"}",
          "legendFormat": "Core {{hrProcessorIndex}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "avg(hrProcessorLoad{instance=\"$instance\"})",
          "legendFormat": "Average",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Average"},
            "properties": [
              {"id": "custom.lineWidth", "value": 2},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "orange"}}
            ]
          }
        ]
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "physicalMemoryUsed{instance=\"$instance\"} * 1024",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "physicalMemorySize{instance=\"$instance\"} * 1024",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {"lineWidth": 1, "fillOpacity": 15, "showPoints": "never"}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Total"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [8, 8]}},
              {"id": "custom.fillOpacity", "value": 0},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "gray"}}
            ]
          }
        ]
      }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Network Traffic",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(ifHCInOctets{instance=\"$instance\", ifDescr!~\"lo.*\"}[5m])",
          "legendFormat": "In — {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(ifHCOutOctets{instance=\"$instance\", ifDescr!~\"lo.*\"}[5m])",
          "legendFormat": "Out — {{ifDescr}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never"}
        },
        "overrides": []
      }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Disk Temperatures",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapDiskTemp_c{instance=\"$instance\"}",
          "legendFormat": "{{diskID}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 45},
              {"color": "red", "value": 55}
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "CPU Temperature",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapCPUTemp_c{instance=\"$instance\"}",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {"lineWidth": 1, "fillOpacity": 10, "showPoints": "never"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 65},
              {"color": "red", "value": 80}
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 11,
      "type": "table",
      "title": "Disk Health",
      "gridPos": {"x": 0, "y": 28, "w": 24, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapDiskTemp_c{instance=\"$instance\"}",
          "legendFormat": "{{diskID}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapDiskSmartStatus{instance=\"$instance\"}",
          "legendFormat": "{{diskID}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapDiskModel{instance=\"$instance\"}",
          "legendFormat": "{{diskID}}",
          "refId": "C",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {"footer": {"show": false}, "sortBy": []},
      "fieldConfig": {
        "defaults": {
          "custom": {"filterable": false}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value #A"},
            "properties": [
              {"id": "displayName", "value": "Temp (°C)"},
              {"id": "unit", "value": "celsius"},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 45}, {"color": "red", "value": 55}]}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "qnapDiskSmartStatus"},
            "properties": [{"id": "displayName", "value": "SMART"}]
          },
          {
            "matcher": {"id": "byName", "options": "qnapDiskModel"},
            "properties": [{"id": "displayName", "value": "Model"}]
          }
        ]
      },
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "job": true, "instance": true, "diskIndex": true, "__name__": true, "Value #B": true, "Value #C": true},
          "renameByName": {"diskID": "Disk"}
        }}
      ]
    },

    {
      "id": 12,
      "type": "table",
      "title": "Network Interfaces",
      "gridPos": {"x": 0, "y": 34, "w": 24, "h": 5},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "ifOperStatus{instance=\"$instance\", ifDescr!~\"lo.*\"}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "ifHighSpeed{instance=\"$instance\", ifDescr!~\"lo.*\"}",
          "refId": "B",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {"footer": {"show": false}, "sortBy": []},
      "fieldConfig": {
        "defaults": {"custom": {"filterable": false}},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value #A"},
            "properties": [
              {"id": "displayName", "value": "Status"},
              {"id": "custom.displayMode", "value": "color-background"},
              {"id": "mappings", "value": [{"type": "value", "options": {"1": {"text": "Up", "color": "green"}, "2": {"text": "Down", "color": "red"}}}]}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Value #B"},
            "properties": [{"id": "displayName", "value": "Speed (Mbps)"}]
          }
        ]
      },
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {
          "excludeByName": {"Time": true, "job": true, "instance": true, "ifIndex": true, "__name__": true},
          "renameByName": {"ifDescr": "Interface"}
        }}
      ]
    }

  ]
}
