{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__elements": {},
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "QNAP NAS monitoring via SNMP — CPU, memory, network, disk I/O, temps, fans, power",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["qnap", "nas", "snmp"],
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "QNAP NAS",
  "uid": "qnap-nas-monitor",
  "version": 1,
  "weekStart": "",
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {
          "selected": false,
          "text": "192.168.1.34",
          "value": "192.168.1.34"
        },
        "hide": 0,
        "label": "Instance",
        "name": "instance",
        "options": [{"selected": true, "text": "192.168.1.34", "value": "192.168.1.34"}],
        "query": "192.168.1.34",
        "type": "custom"
      }
    ]
  },
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapCPUUsage{instance=\"$instance\"}",
          "legendFormat": "CPU",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "CPU Temperature",
      "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapCPUTemperatureCelsius{instance=\"$instance\"}",
          "legendFormat": "CPU",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 65},
              {"color": "red", "value": 80}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "System Temperature",
      "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapSystemTemperatureCelsius{instance=\"$instance\"}",
          "legendFormat": "System",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 65}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Fan Speeds",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapFanSpeed{instance=\"$instance\"}",
          "legendFormat": "{{fanID}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rotrpm",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 400},
              {"color": "yellow", "value": 3500}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "Running Processes",
      "gridPos": {"x": 18, "y": 0, "w": 3, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "count(hrSWRunType{instance=\"$instance\"})",
          "legendFormat": "Processes",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {"mode": "fixed", "fixedColor": "blue"}
        },
        "overrides": []
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Disk Temperatures",
      "gridPos": {"x": 21, "y": 0, "w": 3, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapDiskTemperatureCelsius{instance=\"$instance\"}",
          "legendFormat": "{{diskID}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 45},
              {"color": "red", "value": 55}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Usage",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapCPUUsage{instance=\"$instance\"}",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "single", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Usage",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "hrStorageUsed{instance=\"$instance\", hrStorageDescr=~\".*(emory|RAM).*\"} * hrStorageAllocationUnits{instance=\"$instance\", hrStorageDescr=~\".*(emory|RAM).*\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "hrStorageSize{instance=\"$instance\", hrStorageDescr=~\".*(emory|RAM).*\"} * hrStorageAllocationUnits{instance=\"$instance\", hrStorageDescr=~\".*(emory|RAM).*\"}",
          "legendFormat": "Total",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 15,
            "gradientMode": "none",
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Total"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [8, 8]}},
              {"id": "custom.fillOpacity", "value": 0},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "gray"}}
            ]
          }
        ]
      }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Network Traffic",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(ifHCInOctets{instance=\"$instance\", ifDescr!~\"lo.*\"}[5m])",
          "legendFormat": "In — {{ifDescr}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(ifHCOutOctets{instance=\"$instance\", ifDescr!~\"lo.*\"}[5m])",
          "legendFormat": "Out — {{ifDescr}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Network Bandwidth (Mbps link speed)",
      "gridPos": {"x": 0, "y": 20, "w": 12, "h": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "ifHighSpeed{instance=\"$instance\", ifDescr!~\"lo.*\"}",
          "legendFormat": "{{ifDescr}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {"values": false, "calcs": ["lastNotNull"], "fields": ""},
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "type": "stat",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "displayName": "${__series.name}",
          "color": {"mode": "fixed", "fixedColor": "green"}
        },
        "overrides": []
      }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Disk I/O",
      "gridPos": {"x": 12, "y": 20, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(diskIONRead{instance=\"$instance\", diskIODevice!~\"loop.*|ram.*|dm.*\"}[5m])",
          "legendFormat": "Read — {{diskIODevice}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "rate(diskIONWrite{instance=\"$instance\", diskIODevice!~\"loop.*|ram.*|dm.*\"}[5m])",
          "legendFormat": "Write — {{diskIODevice}}",
          "refId": "B"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "table", "placement": "bottom", "showLegend": true, "calcs": ["mean", "max"]}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never"
          }
        },
        "overrides": []
      }
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "Disk Temperatures",
      "gridPos": {"x": 0, "y": 24, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapDiskTemperatureCelsius{instance=\"$instance\"}",
          "legendFormat": "{{diskID}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 45},
              {"color": "red", "value": 55}
            ]
          }
        },
        "overrides": []
      }
    },

    {
      "id": 13,
      "type": "timeseries",
      "title": "Fan Speeds",
      "gridPos": {"x": 12, "y": 24, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapFanSpeed{instance=\"$instance\"}",
          "legendFormat": "{{fanID}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {"mode": "multi", "sort": "none"},
        "legend": {"displayMode": "list", "placement": "bottom", "showLegend": true}
      },
      "fieldConfig": {
        "defaults": {
          "unit": "rotrpm",
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never"
          },
          "color": {"mode": "palette-classic"}
        },
        "overrides": []
      }
    },

    {
      "id": 14,
      "type": "table",
      "title": "Disk Health",
      "gridPos": {"x": 0, "y": 32, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "qnapDiskTemperatureCelsius{instance=\"$instance\"}",
          "legendFormat": "{{diskID}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "footer": {"show": false},
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "displayMode": "color-background",
            "filterable": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 45},
              {"color": "red", "value": 55}
            ]
          },
          "color": {"mode": "thresholds"}
        },
        "overrides": []
      },
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"__name__": true, "job": true, "instance": true, "diskIndex": true}, "renameByName": {"diskID": "Disk", "Value": "Temp (°C)"}}}
      ]
    },

    {
      "id": 15,
      "type": "table",
      "title": "Network Interface Status",
      "gridPos": {"x": 12, "y": 32, "w": 12, "h": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "ifOperStatus{instance=\"$instance\", ifDescr!~\"lo.*\"}",
          "legendFormat": "{{ifDescr}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "ifHighSpeed{instance=\"$instance\", ifDescr!~\"lo.*\"}",
          "legendFormat": "{{ifDescr}}",
          "refId": "B",
          "instant": true,
          "format": "table"
        }
      ],
      "options": {
        "footer": {"show": false},
        "sortBy": []
      },
      "fieldConfig": {
        "defaults": {
          "custom": {"filterable": false}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Value #A"},
            "properties": [
              {"id": "displayName", "value": "Oper Status"},
              {"id": "mappings", "value": [
                {"type": "value", "options": {"1": {"text": "Up", "color": "green"}, "2": {"text": "Down", "color": "red"}}}
              ]},
              {"id": "custom.displayMode", "value": "color-background"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Value #B"},
            "properties": [
              {"id": "displayName", "value": "Speed (Mbps)"}
            ]
          }
        ]
      },
      "transformations": [
        {"id": "merge", "options": {}},
        {"id": "organize", "options": {"excludeByName": {"__name__": true, "job": true, "instance": true, "ifIndex": true}, "renameByName": {"ifDescr": "Interface"}}}
      ]
    }

  ]
}
